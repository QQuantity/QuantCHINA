class CloudQuantSystem:
    def __init__(self):
        self.cache = {}
        
    def get_stock_data(self, symbol, days=120):
        """获取股票数据（云优化版）"""
        try:
            end_date = datetime.now()
            start_date = end_date - timedelta(days=days)
            
            # 使用AkShare获取数据
            df = ak.stock_zh_a_hist(
                symbol=symbol,
                period="daily",
                start_date=start_date.strftime('%Y%m%d'),
                end_date=end_date.strftime('%Y%m%d'),
                adjust="qfq"
            )
            
            if df is None or df.empty:
                return None
                
            df['日期'] = pd.to_datetime(df['日期'])
            df.set_index('日期', inplace=True)
            df.rename(columns={
                '开盘': 'open', '收盘': 'close', '最高': 'high',
                '最低': 'low', '成交量': 'volume', '成交额': 'amount'
            }, inplace=True)
            
            return df.sort_index()
            
        except Exception as e:
            st.error(f"数据获取失败: {str(e)}")
            return None
    
    def calculate_indicators(self, df):
        """计算技术指标"""
        df = df.copy()
        # 均线
        df['ma5'] = talib.SMA(df['close'], timeperiod=5)
        df['ma20'] = talib.SMA(df['close'], timeperiod=20)
        df['ma60'] = talib.SMA(df['close'], timeperiod=60)
        
        # MACD
        df['macd'], df['macd_signal'], df['macd_hist'] = talib.MACD(
            df['close'], fastperiod=12, slowperiod=26, signalperiod=9
        )
        
        # RSI
        df['rsi'] = talib.RSI(df['close'], timeperiod=14)
        
        # 波动率
        df['atr'] = talib.ATR(df['high'], df['low'], df['close'], timeperiod=14)
        df['volatility'] = df['close'].pct_change().rolling(20).std()
        
        # 成交量
        df['volume_ma5'] = df['volume'].rolling(5).mean()
        df['volume_ratio'] = df['volume'] / df['volume_ma5']
        
        return df
    
    def detect_signals(self, df):
        """检测交易信号"""
        signals = []
        df = self.calculate_indicators(df)
        
        for i in range(60, len(df)-1):
            current = df.iloc[i]
            
            # 多头条件
            trend_ok = current['close'] > current['ma20'] > current['ma60']
            volume_surge = current['volume_ratio'] > 2.0
            price_break = current['close'] > df['high'].iloc[i-20:i].max() * 0.99
            macd_ok = current['macd'] > current['macd_signal'] and current['macd_hist'] > 0
            rsi_ok = 40 < current['rsi'] < 70
            
            if trend_ok and volume_surge and price_break and macd_ok and rsi_ok:
                # 预测未来10%概率（简化版）
                prob = min(75, current['volume_ratio'] * 15 + (current['rsi']-40)/30*25)
                
                signals.append({
                    'date': df.index[i],
                    'price': current['close'],
                    'atr': current['atr'],
                    'rsi': current['rsi'],
                    'volume_ratio': current['volume_ratio'],
                    'prob_10pct': prob
                })
        
        return pd.DataFrame(signals), df
    
    def predict_with_ml(self, df):
        """机器学习预测（简化在线训练）"""
        try:
            if len(df) < 100:
                return 50.0
            
            # 特征工程
            df['returns_5d'] = df['close'].pct_change(5).shift(-5)
            df['target'] = (df['returns_5d'] > 0.10).astype(int)
            
            features = ['volume_ratio', 'rsi', 'volatility', 'macd_hist']
            df_model = df.dropna()
            
            if len(df_model) < 50:
                return 50.0
            
            X = df_model[features].fillna(0)
            y = df_model['target']
            
            model = RandomForestClassifier(n_estimators=50, max_depth=4, random_state=42)
            model.fit(X[:-5], y[:-5])  # 用历史数据训练
            
            latest = X.iloc[-1:]
            prob = model.predict_proba(latest)[0][1] * 100
            return round(prob, 1)
            
        except Exception:
            return 50.0
    
    def plot_chart(self, df, signals, symbol):
        """绘制交互式图表"""
        fig = make_subplots(
            rows=3, cols=1,
            shared_xaxes=True,
            vertical_spacing=0.05,
            row_heights=[0.6, 0.2, 0.2],
            subplot_titles=('K线与信号', '成交量', 'MACD')
        )
        
        # K线
        fig.add_trace(go.Candlestick(
            x=df.index, open=df['open'], high=df['high'],
            low=df['low'], close=df['close'], name='K线'
        ), row=1, col=1)
        
        # 均线
        fig.add_trace(go.Scatter(x=df.index, y=df['ma5'], name='MA5', line=dict(color='orange')), row=1, col=1)
        fig.add_trace(go.Scatter(x=df.index, y=df['ma20'], name='MA20', line=dict(color='blue')), row=1, col=1)
        
        # 信号点
        if not signals.empty:
            fig.add_trace(go.Scatter(
                x=signals['date'], y=signals['price'],
                mode='markers+text',
                marker=dict(size=12, color='red', symbol='triangle-up'),
                text=[f"{p:.0f}%" for p in signals['prob_10pct']],
                textposition="top center",
                name='买入信号'
            ), row=1, col=1)
        
        # 成交量
        colors = ['red' if c >= o else 'green' for c, o in zip(df['close'], df['open'])]
        fig.add_trace(go.Bar(x=df.index, y=df['volume'], marker_color=colors, name='成交量'), row=2, col=1)
        
        # MACD
        fig.add_trace(go.Scatter(x=df.index, y=df['macd'], name='MACD'), row=3, col=1)
        fig.add_trace(go.Scatter(x=df.index, y=df['macd_signal'], name='Signal'), row=3, col=1)
        fig.add_trace(go.Bar(x=df.index, y=df['macd_hist'], marker_color='gray', name='Histogram'), row=3, col=1)
        
        fig.update_layout(height=800, showlegend=False, template='plotly_white')
        return fig
    
    def get_exit_strategy(self, price, atr):
        """计算卖出策略"""
        return {
            'stop_loss': round(price - 2*atr, 2),
            'target_10pct': round(price * 1.10, 2),
            'target_optimal': round(price + 3*atr, 2),
            'risk_reward': 3.0
        }

